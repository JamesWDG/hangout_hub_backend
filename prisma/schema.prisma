// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  SIMPLE
  EVENT
  POLL
}



model User {
  id String @id @default(uuid()) 
  email String @unique
  password String
  firstName String
  lastName String
  phone String
  profilePicture String?
  isVerified Boolean @default(false)
  bio String?
  eventsOfInterest String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  adminOfGroups Group[] @relation("GroupAdmins")
  joinRequests JoinRequest[]
  memberOfGroups Group[] @relation("GroupMembers")
  posts Post[] @relation("author")
  taggedPosts Post[] @relation("taggedUsers")
}

model Otp{
    id String @id @default(uuid()) 
    email String @unique
    otp String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}




// Group Schema 
model Group {
    id String @id @default(uuid())
    name String
    description String
    category String
    image String
    admins User[] @relation("GroupAdmins")
    members User[] @relation("GroupMembers")
    joinRequests JoinRequest[]
    posts Post[] @relation("group")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Join Requests Schema 
model JoinRequest {
    id String @id @default(uuid())
    userId String
    groupId String
    status String //pending , accepted , rejected
    user User @relation(fields: [userId], references: [id])
    group Group @relation(fields: [groupId], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
} 
// Post Schema 



model Post {
      id String @id @default(uuid())
      type PostType
      taggedUsers User[] @relation("taggedUsers")
      userId String
      user User @relation("author", fields: [userId], references: [id])
      groupId String
      group Group @relation("group", fields: [groupId], references: [id])
      simplePost SimplePost?
      eventPost EventPost?
      poll Poll?
      createdAt DateTime @default(now())
      updatedAt DateTime @updatedAt

      @@index([groupId, createdAt])
}


model SimplePost {
  id String @id @default(uuid())
  content String
  image String?
  postId String @unique
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model EventPost {
   id String @id @default(uuid())
   eventName String
   eventDescription String
   eventStartDate DateTime
   eventEndDate DateTime
   eventLocation String
   eventImage String?
   notes String?
   postId String @unique
   post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
   eventRoles EventRoles[] @relation("eventRoles")
   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
}


model EventRoles {
  id String @id @default(uuid())
  roleName String
  roleDescription String
  eventPostId String
  eventPost EventPost @relation("eventRoles", fields: [eventPostId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Poll {
  id String @id @default(uuid())
  pollQuestion String
  postId String @unique
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  pollOptions PollOption[] @relation("pollOptions")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model PollOption {
  id String @id @default(uuid())
  option String
  pollId String
  poll Poll @relation("pollOptions", fields: [pollId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}